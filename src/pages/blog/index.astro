---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sorted = posts.sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);
---

<Layout title="Blog — Shaig Muradov" description="Articles and thoughts by Shaig Muradov">
  <main>
    <div class="container">
      <div class="header">
        <a href="/" class="back"><i class="fa-solid fa-arrow-left"></i> Back</a>
        <h1>Blog</h1>
      </div>

      {sorted.length === 0 ? (
        <p class="empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="post-list">
          {sorted.map(post => (
            <li>
              <a href={`/blog/${post.id}`}>
                <span class="post-title">{post.data.title}</span>
                {post.data.description && (
                  <span class="post-desc">{post.data.description}</span>
                )}
              </a>
              <span class="date">
                {new Date(post.data.publishDate).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric'
                })}
              </span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>

<style>
  main {
    padding: 3rem 1rem;
  }

  .container {
    max-width: 600px;
    margin: 0 auto;
  }

  .header {
    margin-bottom: 2rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .back:hover {
    color: var(--accent);
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .empty {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-list li {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-list li:first-child {
    border-top: 1px solid var(--border);
  }

  .post-list a {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    color: var(--text);
  }

  .post-list a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .post-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .date {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    padding-top: 0.15rem;
  }
</style>
